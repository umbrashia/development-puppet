{
  "name": "Puppet Login",
  "version": "1.0.6",
  "description": "This extension for development login check with using email id and those email id saved automatically in this plugin",
  "manifest_version": 3,
  "author": "Umbrashia Corporation (shantanu sharma)",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background-js/style-changer.js"
  },
  "options_page": "template/export.html",
  "icons": {
    "16": "images/get_started16.png",
    "32": "images/get_started32.png",
    "48": "images/get_started48.png",
    "128": "images/get_started128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/get_started16.png",
      "32": "images/get_started32.png",
      "48": "images/get_started48.png",
      "128": "images/get_started128.png"
    },
    "default_popup": "template/home-popup.html"
  }
}
